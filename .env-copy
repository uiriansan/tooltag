# Porta usada pelo servidor:
PORT=8080

# Onde o banco de dados será salvo:
DB_PATH=deploy/data/database.sqlite
DB_BACKUPS_PATH=deploy/data/db_backups/

# Nome atribuído ao usuário administrador criado automaticamente:
ADM_USERNAME=

# Senha atribuída ao usuário administrador criado automaticamente.
# Esta senha pode ser alterada pelo sistema.
# Também será a senha padrão em caso de reset.
ADM_SENHA=
