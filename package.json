{
    "name": "tooltag",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "db:generate": "drizzle-kit generate --config=src/lib/server/db/drizzle.config.ts",
        "db:migrate": "tsx --env-file=.env src/lib/server/db/migrate_and_seed.ts",
        "db:push": "drizzle-kit push --config=src/lib/server/db/drizzle.config.ts",
        "db:studio": "drizzle-kit studio --config=src/lib/server/db/drizzle.config.ts"
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/adapter-node": "^5.5.7",
        "@sveltejs/kit": "^2.63.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bcrypt": "^6.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/jsonwebtoken": "^9.0.10",
        "drizzle-kit": "^0.31.10",
        "svelte": "^5.56.1",
        "svelte-check": "^4.6.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^12.11.1",
        "drizzle-orm": "^0.45.2",
        "jsonwebtoken": "^9.0.3",
        "qr-scanner": "^1.4.2"
    },
    "allowScripts": {
        "esbuild@0.18.20": true,
        "esbuild@0.25.12": true,
        "esbuild@0.28.1": true,
        "better-sqlite3@12.11.1": true,
        "sharp@0.34.5": true,
        "workerd@1.20260708.1": true,
        "bcrypt@6.0.0": true
    }
}
